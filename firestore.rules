rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@yuliedplay.com' ||
        request.auth.token.email == 'hernandezkevin001998@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['email', 'role']) &&
        (request.resource.data.role == 'user' || isAdmin()); 
      allow update: if isAdmin() || (isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email', 'points']));
      allow delete: if isAdmin();
    }

    // --- Admins Collection (Bootstrapped) ---
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via Firebase Console for safety
    }

    // --- Services ---
    match /services/{serviceId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin();
    }

    // --- Products ---
    match /products/{productId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin();
    }

    // --- Orders ---
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Reviews ---
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- Points Logs ---
    match /points_logs/{logId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false; // Only via function/admin (simulated as false for safety)
      allow write: if isAdmin();
    }

    // --- Availability ---
    match /availability/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Promotions ---
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Bookings ---
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // --- Feedback ---
    match /feedback/{feedbackId} {
      allow create: if true; // Anonymous allowed as requested, but can be restricted to isSignedIn if needed
      allow read: if isAdmin();
    }

    // --- Moodboards ---
    function isValidMoodboard(data) {
      return data.keys().hasAll(['userId', 'image']) &&
        data.userId is string && data.userId == request.auth.uid &&
        data.image is string && data.image.size() < 2000;
    }

    match /moodboards/{itemId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidMoodboard(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
